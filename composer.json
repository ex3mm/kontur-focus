{
  "name": "ex3mm/kontur-focus",
  "description": "Laravel/PHP package for Kontur.Focus API integration",
  "version": "1.0.1",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.5",
    "guzzlehttp/guzzle": "^7.9",
    "kevinrob/guzzle-cache-middleware": "^7.0",
    "psr/cache": "^3.0",
    "psr/log": "^3.0",
    "symfony/cache": "^7.3"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.0",
    "orchestra/testbench": "^10.0",
    "pestphp/pest": "^3.8",
    "pestphp/pest-plugin-type-coverage": "^3.0",
    "phpstan/phpstan": "^2.1",
    "rector/rector": "^2.0"
  },
  "suggest": {
    "illuminate/support": "Required for Laravel integration (^12.0)"
  },
  "autoload": {
    "psr-4": {
      "Ex3mm\\KonturFocus\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Ex3mm\\KonturFocus\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Ex3mm\\KonturFocus\\Laravel\\KonturFocusServiceProvider"
      ],
      "aliases": {
        "KonturFocus": "Ex3mm\\KonturFocus\\Laravel\\Facades\\KonturFocus"
      }
    }
  },
  "scripts": {
    "test": "vendor/bin/pest",
    "phpstan": "vendor/bin/phpstan analyse --configuration=phpstan.neon --memory-limit=1G",
    "cs:check": "vendor/bin/php-cs-fixer fix --dry-run --diff",
    "cs:fix": "vendor/bin/php-cs-fixer fix"
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  }
}
